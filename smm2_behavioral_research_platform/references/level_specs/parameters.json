{
  "_meta": {
    "description": "Machine-readable IV parameters for all SMM2 Behavioral Research Platform levels. Used by analysis notebooks to label conditions and fit models.",
    "version": "1.0",
    "game_style": "SMB1",
    "smm2_version": "3.0.2+"
  },

  "positive_reinforcement": {
    "spec_file": "01_positive_reinforcement.md",
    "zones": [
      {"zone": "CRF",        "schedule": "FR1",  "fr_value": 1,  "vr_mean": null, "interval_s": null, "blocks": 10},
      {"zone": "FR3",        "schedule": "FR3",  "fr_value": 3,  "vr_mean": null, "interval_s": null, "blocks": 10},
      {"zone": "VR3",        "schedule": "VR3",  "fr_value": null,"vr_mean": 3,   "interval_s": null, "blocks": 10,
       "vr_sequence": [1,3,5,2,4,3,1,5,2,3]},
      {"zone": "Extinction", "schedule": "EXT",  "fr_value": null,"vr_mean": null,"interval_s": null, "blocks": 10}
    ],
    "reinforcer": "coin",
    "reinforcer_magnitude": 1,
    "zone_order": "fixed"
  },

  "negative_reinforcement": {
    "spec_file": "02_negative_reinforcement.md",
    "zones": [
      {"zone": "Escape",    "paradigm": "escape",    "warning_signal": false, "trials": 10},
      {"zone": "Avoidance", "paradigm": "avoidance", "warning_signal": true,  "trials": 10,
       "warning_onset_tiles": 4},
      {"zone": "Mixed",     "paradigm": "mixed",     "warning_signal": "varied", "trials": 10}
    ],
    "aversive": "Goomba",
    "aversive_consequence": "power_up_loss",
    "starting_state": "Super Mario",
    "goomba_patrol_range_tiles": 3
  },

  "reinforcement_schedules": {
    "spec_file": "03_reinforcement_schedules.md",
    "zones": [
      {"zone": "FR",  "schedule": "FR3",   "fr_value": 3,    "vr_mean": null,  "interval_s": null,
       "response_opportunities": 10, "zone_order": 1},
      {"zone": "VR",  "schedule": "VR3",   "fr_value": null, "vr_mean": 3,     "interval_s": null,
       "response_opportunities": 10, "zone_order": 2,
       "vr_sequence": [1,3,5,2,4,3,1,5,2,3]},
      {"zone": "FI",  "schedule": "FI5",   "fr_value": null, "vr_mean": null,  "interval_s": 5,
       "response_opportunities": 10, "zone_order": 3},
      {"zone": "VI",  "schedule": "VI5.5", "fr_value": null, "vr_mean": null,  "interval_s": 5.5,
       "response_opportunities": 10, "zone_order": 4,
       "vi_sequence_s": [3,7,4,8,5,6,3,9,4,6]}
    ],
    "reinforcer": "coin",
    "reinforcer_magnitude": 1,
    "zone_order": "fixed"
  },

  "extinction": {
    "spec_file": "04_extinction.md",
    "sessions": [
      {"session": 1, "label": "Baseline",          "condition": "CRF",        "schedule": "FR1", "blocks": 20},
      {"session": 2, "label": "Extinction",         "condition": "Extinction", "schedule": "EXT", "blocks": 20},
      {"session": 3, "label": "Spontaneous Recovery","condition": "CRF",       "schedule": "FR1", "blocks": 20},
      {"session": 4, "label": "Re-extinction",      "condition": "Extinction", "schedule": "EXT", "blocks": 20}
    ],
    "reinforcer": "coin",
    "reinforcer_magnitude": 1,
    "block_spacing_tiles": 4,
    "inter_session_break_same_day_min": 15,
    "inter_session_break_across_days_h": 24
  },

  "shaping": {
    "spec_file": "05_shaping.md",
    "steps": [
      {"step": 1, "label": "Platform approach",    "difficulty": "low",       "criterion_successes": 3, "max_trials": 10},
      {"step": 2, "label": "Small jump",           "difficulty": "moderate",  "criterion_successes": 3, "max_trials": 10},
      {"step": 3, "label": "Gap clear",            "difficulty": "high",      "criterion_successes": 3, "max_trials": 10},
      {"step": 4, "label": "Moving platform",      "difficulty": "very_high", "criterion_successes": 3, "max_trials": 10},
      {"step": 5, "label": "Precision corridor",   "difficulty": "terminal",  "criterion_successes": 3, "max_trials": 10}
    ],
    "chaining_method": "forward",
    "reinforcer": "coin",
    "backslide_rule": "3_consecutive_failures",
    "donut_lift_duration_s": 2
  },

  "stimulus_control": {
    "spec_file": "06_stimulus_control.md",
    "sd": {"label": "Night background", "smm2_filter": "night", "color_description": "blue"},
    "s_delta": {"label": "Sunset background", "smm2_filter": "sunset", "color_description": "orange"},
    "blocks_per_zone": 5,
    "zones_per_session": 8,
    "sd_zones_per_session": 4,
    "sdelta_zones_per_session": 4,
    "zone_orders": {
      "A": ["SD","Sdelta","SD","Sdelta","SD","Sdelta","SD","Sdelta"],
      "B": ["Sdelta","SD","Sdelta","SD","Sdelta","SD","Sdelta","SD"],
      "C": ["SD","SD","Sdelta","Sdelta","SD","Sdelta","SD","Sdelta"]
    },
    "sessions": 3,
    "reinforcer": "coin",
    "reinforcer_magnitude": 1
  },

  "generalization": {
    "spec_file": "07_generalization.md",
    "training_stimulus": {"label": "Ground/Night", "smm2_theme": "ground", "smm2_filter": "night"},
    "generalization_stimuli": [
      {"order": 1, "label": "Underground", "smm2_theme": "underground", "similarity": 0.75},
      {"order": 2, "label": "Water",       "smm2_theme": "water",       "similarity": 0.50},
      {"order": 3, "label": "Castle",      "smm2_theme": "castle",      "similarity": 0.25},
      {"order": 4, "label": "Airship",     "smm2_theme": "airship",     "similarity": 0.10}
    ],
    "training_schedule": "CRF",
    "probe_schedule": "EXT",
    "blocks_per_segment": 5,
    "design": "multiple_probe_with_retraining",
    "sessions": 2
  },

  "punishment": {
    "spec_file": "08_punishment.md",
    "punishment_type": "positive_punishment",
    "punisher": "Buzzy Beetle contact",
    "punisher_consequence": "power_up_loss",
    "starting_state": "Super Mario",
    "punished_path": "left",
    "unpunished_path": "right",
    "left_path_temptation_coins": 3,
    "right_path_coins": 1,
    "design": "ABAB_reversal",
    "phases": [
      {"phase": "A1", "punishment": true,  "trials": 10},
      {"phase": "B1", "punishment": false, "trials": 10},
      {"phase": "A2", "punishment": true,  "trials": 10},
      {"phase": "B2", "punishment": false, "trials": 10}
    ]
  },

  "chaining": {
    "spec_file": "09_chaining.md",
    "chain_length": 4,
    "chaining_method": "forward",
    "links": [
      {"link": 1, "response": "Hit P-switch 1",     "sr_plus": "Blue coin trail appears",    "sd_next": "Coin trail on ground"},
      {"link": 2, "response": "Hit ON/OFF switch",   "sr_plus": "Barrier wall disappears",    "sd_next": "Open corridor visible"},
      {"link": 3, "response": "Hit P-switch 2",      "sr_plus": "Note-block bridge appears",  "sd_next": "Bridge over pit"},
      {"link": 4, "response": "Cross bridge to flag","sr_plus": "Level complete fanfare",      "sd_next": null}
    ],
    "p_switch_duration_s": 10,
    "trial_blocks": [
      {"trial_range": [1,3],   "links_available": 1},
      {"trial_range": [4,6],   "links_available": 2},
      {"trial_range": [7,9],   "links_available": 3},
      {"trial_range": [10,15], "links_available": 4}
    ],
    "max_trials": 15
  },

  "matching_law": {
    "spec_file": "10_matching_law.md",
    "conditions": [
      {"condition": "A", "left_coins": 3, "right_coins": 1, "ratio": "3:1"},
      {"condition": "B", "left_coins": 2, "right_coins": 2, "ratio": "1:1"},
      {"condition": "C", "left_coins": 1, "right_coins": 3, "ratio": "1:3"},
      {"condition": "D", "left_coins": 5, "right_coins": 1, "ratio": "5:1"},
      {"condition": "E", "left_coins": 1, "right_coins": 5, "ratio": "1:5"}
    ],
    "choices_per_session": 30,
    "path_length_tiles": 8,
    "loop_design": true,
    "sessions": 5,
    "session_order": "latin_square_counterbalanced",
    "analysis": {
      "model": "generalized_matching_law",
      "equation": "log(B1/B2) = a * log(R1/R2) + log(b)",
      "parameters": ["sensitivity_a", "bias_b"]
    }
  },

  "explore_exploit": {
    "spec_file": "11_explore_exploit.md",
    "branch_points_per_run": 2,
    "exploit_reward_bp1": 4,
    "exploit_reward_bp2": 2,
    "explore_path_length_penalty_tiles": 4,
    "level_timer_s": 100,
    "blocks": [
      {"block": 1, "runs": [1,5],   "explore_reward": 0, "label": "EV_zero_initial"},
      {"block": 2, "runs": [6,10],  "explore_reward": 8, "label": "EV_high"},
      {"block": 3, "runs": [11,15], "explore_reward": 3, "label": "EV_tied"},
      {"block": 4, "runs": [16,20], "explore_reward": 0, "label": "EV_zero_retest"}
    ],
    "total_runs": 20,
    "analysis": {
      "primary_dv": "exploration_rate",
      "secondary_dvs": ["exploration_decay_slope", "reward_sensitivity"],
      "models": [
        {"model": "epsilon_greedy", "parameter": "epsilon"},
        {"model": "UCB1",          "parameter": "c"},
        {"model": "softmax",       "parameter": "temperature"}
      ],
      "directed_vs_random_coding": "run_1_of_block = directed_proxy; runs_3_to_5 = random_proxy"
    }
  },

  "behavioral_momentum": {
    "spec_file": "12_behavioral_momentum.md",
    "tracks": [
      {
        "track": "rich",
        "baseline_schedule": "CRF",
        "fr_value": 1,
        "blocks_per_session": 30,
        "reinforcers_per_session": 30,
        "theme": "ground_day"
      },
      {
        "track": "lean",
        "baseline_schedule": "FR10",
        "fr_value": 10,
        "blocks_per_session": 30,
        "reinforcers_per_session": 3,
        "theme": "underground"
      }
    ],
    "disruptor": {
      "type": "free_reinforcers",
      "free_coins": 5,
      "delivery": "passive_ground_coins"
    },
    "extinction_blocks_post_disruption": 15,
    "phases": [
      {"phase": "baseline",    "sessions": 3, "tracks": ["rich", "lean"], "alternated": true},
      {"phase": "disruption",  "sessions": 3, "tracks": ["rich", "lean"], "within_session": true}
    ],
    "analysis": {
      "primary_dv": "resistance_to_change_ratio",
      "formula": "responses_extinction / responses_baseline",
      "model": "Nevin_1992",
      "equation": "log(B_d / B_0) = -b * d * r^(-a)"
    }
  },

  "amelioration": {
    "spec_file": "13_amelioration.md",
    "conditions": [
      {
        "condition": "FR_FR",
        "left_schedule":  "FR3",
        "right_schedule": "FR9",
        "left_fr":  3,
        "right_fr": 9,
        "richness_ratio": "3:1",
        "path_length_equal": false,
        "left_path_tiles": 6,
        "right_path_tiles": 18,
        "molar_prediction": "exclusive_preference",
        "melioration_prediction": "exclusive_preference"
      },
      {
        "condition": "VI_VI",
        "left_schedule":  "VI3s",
        "right_schedule": "VI9s",
        "left_vi_mean_s":  3,
        "right_vi_mean_s": 9,
        "left_vi_sequence_s":  [1,4,2,5,3,4,1,6,2,4],
        "right_vi_sequence_s": [5,12,7,11,9,8,10,13,6,9],
        "richness_ratio": "3:1",
        "path_length_equal": true,
        "path_tiles": 6,
        "molar_prediction": "matching_75_25",
        "melioration_prediction": "matching_via_local_rate_equalization"
      }
    ],
    "choices_per_condition": 40,
    "session_order": "counterbalanced",
    "analysis": {
      "molar": {
        "model": "generalized_matching_law",
        "expected_sensitivity_FR_FR": "<1 (exclusive preference)",
        "expected_sensitivity_VI_VI": "~1 (matching)"
      },
      "local_rate": {
        "window_choices": 5,
        "metrics": ["run_length", "switch_probability", "local_rate_advantage"],
        "melioration_test": "P(switch_to_left | local_rate_left > local_rate_right) > P(switch_to_left | local_rate_left < local_rate_right)"
      }
    }
  }
}
